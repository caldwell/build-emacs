#!/usr/bin/env ruby

require 'json'
require_relative 'verbose-shell'

Vsh = VerboseShell
Vsh.verbose = true

abort "Usage: #{$0} dep_tar_files..." unless ARGV.count > 0

def shortest_common_prefix(*strings)
  max, min = strings.max.split(//), strings.min.split(//)
  strings[0].slice(0, max.each_with_index.find { |x, y| x != min[y] }[1])
end

deps = ARGV.dup
base = shortest_common_prefix(*deps.map { |d| File.basename(d) })

deps_dir = "#{base}-dependencies"
Vsh.rm_rf   deps_dir
Vsh.mkdir_p "#{deps_dir}/archives"

deps.each do |ar|
  Vsh.cd("#{deps_dir}/archives") { Vsh.system(*%W"tar xf ../../#{ar} --strip-components 1") }
  Vsh.capture(*%W"tar tf #{ar} *.tar.*").split.each do |f|
    puts f
    n=File.basename f
    d=File.basename ar
    d=d.delete_prefix("#{base}-").delete_suffix("-dependencies.tar")
    Vsh.mkdir_p "#{deps_dir}/#{d}"
    Vsh.ln_sf "../archives/#{n}", "#{deps_dir}/#{d}/"
  end
end

Vsh.system(*%W"tar cf #{deps_dir}.tar #{deps_dir}")
Vsh.rm_rf deps_dir
